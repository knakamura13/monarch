{
    "name": "monarch-case-tracker",
    "private": true,
    "version": "0.2.0",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "start": "node build",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:components": "vitest run --config vitest.component.config.ts",
        "test:components:watch": "vitest --config vitest.component.config.ts",
        "test:e2e": "playwright test",
        "db:purge-users": "tsx scripts/purge-old-users.ts",
        "db:create-table": "tsx scripts/create-table.ts",
        "report:undefined-classes": "tsx scripts/find-undefined-classes.ts"
    },
    "dependencies": {
        "@aws-sdk/client-dynamodb": "^3.1045.0",
        "@aws-sdk/client-s3": "^3.1045.0",
        "@aws-sdk/lib-dynamodb": "^3.1045.0",
        "@aws-sdk/s3-request-presigner": "^3.1045.0",
        "@better-auth/passkey": "^1.6.9",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@melt-ui/svelte": "^0.86.6",
        "@node-rs/argon2": "^2.0.2",
        "@opentelemetry/api": "^1.9.1",
        "better-auth": "^1.6.9",
        "date-fns": "^4.1.0",
        "svelte-sonner": "^1.1.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@melt-ui/pp": "^0.3.2",
        "@playwright/test": "^1.59.1",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/kit": "^2.59.1",
        "@sveltejs/vite-plugin-svelte": "^5.1.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/svelte": "^5.3.1",
        "@types/node": "^22.19.18",
        "@typescript-eslint/eslint-plugin": "^8.59.2",
        "@typescript-eslint/parser": "^8.59.2",
        "@vite-pwa/sveltekit": "^1.1.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-svelte": "^2.46.1",
        "globals": "^15.15.0",
        "happy-dom": "^20.9.0",
        "jsdom": "^29.1.1",
        "lucide-svelte": "^0.468.0",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "svelte": "^5.55.5",
        "svelte-check": "^4.4.8",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^6.4.2",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=22"
    }
}
